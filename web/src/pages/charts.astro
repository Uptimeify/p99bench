---
import Base from '../layouts/Base.astro';
import Chart from '../components/Chart.astro';
import { loadIndex, loadResults } from '../lib/data';
import { priceVsGrade, fsyncBars, sustainedBars } from '../lib/charts';

const rows = loadIndex();
const runs = loadResults();
const scatter = priceVsGrade(rows, 'postgres_oltp');
const fsync = fsyncBars(rows);
const sustained = sustainedBars(runs);
---
<Base title="p99bench — charts">
  <h1>Charts</h1>

  <h2>Price vs. postgres_oltp grade</h2>
  <p>Lower y is a better grade (A=top). Cheap-and-good sits bottom-left.</p>
  <Chart id="scatter" type="scatter"
    data={{ datasets: [{ label: 'hosts',
      data: scatter.map((p) => ({ x: p.x, y: p.y })),
      backgroundColor: scatter.map((p) => p.color) }] }}
    options={{ scales: { y: { reverse: true, ticks: { callback: (v: number) => ['A','B','C','D','F'][v] ?? '' } },
      x: { title: { display: true, text: '€/month' } } } }} />

  <h2>fsync p99.9 (worst) per host</h2>
  <Chart id="fsync" type="bar"
    data={{ labels: fsync.labels, datasets: [{ label: 'µs', data: fsync.values }] }}
    options={{ scales: { y: { type: 'logarithmic', title: { display: true, text: 'µs (log)' } } } }} />

  <h2>Sustained disk: first vs last minute IOPS</h2>
  <p>Not a time series — only first-minute and last-minute samples exist.</p>
  <Chart id="sustained" type="bar"
    data={{ labels: sustained.labels, datasets: [
      { label: 'first min', data: sustained.firstMin },
      { label: 'last min', data: sustained.lastMin }] }} />
</Base>
