---
import Base from '../../../../layouts/Base.astro';
import GradeChip from '../../../../components/GradeChip.astro';
import MetricTable from '../../../../components/MetricTable.astro';
import BarChart from '../../../../components/BarChart.astro';
import CdfChart from '../../../../components/CdfChart.astro';
import Decoder from '../../../../components/Decoder.astro';
import { loadResults } from '../../../../lib/data';
import { hostChartSections } from '../../../../lib/hostcharts';
import { fsyncCdf } from '../../../../lib/cdf';
import { decoderRows } from '../../../../lib/decoder';

export function getStaticPaths() {
  return loadResults().map((r) => ({
    params: { provider: r.slug.provider, region: r.slug.region, stamp: r.slug.stamp },
    props: { result: r.data },
  }));
}

const { result } = Astro.props;
const run = result.run;
const provider = result.provider;
const cats = result.grades?.categories ?? {};
const profiles = result.grades?.profiles ?? {};
const sections = hostChartSections(result);
const CAT_NAME: Record<string, string> = { disk: 'Disk', cpu: 'CPU', ram: 'RAM', network: 'Network' };
const cdf = fsyncCdf(result);
const fsyncGrade = cats.disk?.metrics?.['disk.wal_fsync.p999_us']?.grade;
const decode = decoderRows(result);
---
<Base title={`${provider.name} ${provider.region} — ${provider.product}`}>
  <h1>{provider.name} / {provider.region} — {provider.product}</h1>
  <p class="meta">
    €{provider.price_eur_month}/mo · storage {result.grades?.storage_class ?? '—'} ·
    host <code>{run.host_id}</code> · {run.timestamp_utc} · submitter {run.submitter ?? '—'}
  </p>
  {run.notes && <p class="notes">Notes: {run.notes}</p>}

  <h2>Profiles</h2>
  <div class="tscroll"><table>
    <thead><tr><th>profile</th><th>grade</th><th>bound by</th></tr></thead>
    <tbody>
      {Object.entries(profiles).map(([name, p]: any) => (
        <tr><td>{name}</td><td><GradeChip grade={p.grade} /></td><td><code>{p.bound_by ?? '—'}</code></td></tr>
      ))}
    </tbody>
  </table></div>

  {(cdf.length > 0 || decode.length > 0) && (
    <section>
      <div class="cat-head"><h2>Tail-latency reality</h2></div>
      <div class="two-up">
        {cdf.length > 0 && (
          <div>
            <p class="eyebrow" style="margin:0 0 .5rem">fsync cumulative distribution</p>
            <CdfChart points={cdf} grade={fsyncGrade} id="cdf-fsync" />
            <p class="cdf-cap">
              Points are the measured p50 / p99 / p99.9 / max — the line between them is
              interpolated (we store percentiles, not a full histogram). Fixed axis:
              a tight curve on the left is a good host; a curve swept right is an exploding tail.
            </p>
          </div>
        )}
        {decode.length > 0 && (
          <div>
            <p class="eyebrow" style="margin:0 0 .5rem">marketing claim vs measured</p>
            <Decoder rows={decode} />
          </div>
        )}
      </div>
    </section>
  )}

  {sections.map((s) => (
    <section>
      <div class="cat-head">
        <GradeChip grade={s.grade} class="lg" />
        <h2>{CAT_NAME[s.key] ?? s.key}</h2>
        {s.boundBy && <span class="bound">bound by {s.boundBy}</span>}
      </div>
      <div class="charts">
        {s.groups.map((g) => <BarChart group={g} />)}
      </div>
      {cats[s.key]?.metrics && (
        <details class="exact">
          <summary>exact values &amp; per-metric grades</summary>
          <MetricTable
            title=""
            metrics={Object.fromEntries(
              Object.entries(cats[s.key].metrics).map(([m, v]: any) => [m, { grade: v.grade, value: v.value }])
            )}
          />
        </details>
      )}
    </section>
  ))}
</Base>
