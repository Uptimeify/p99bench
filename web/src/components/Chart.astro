---
interface Props { id: string; type: string; data: unknown; options?: unknown; }
const { id, type, data, options = {} } = Astro.props;
---
<canvas id={id} width="800" height="360"></canvas>
<script type="application/json" set:html={JSON.stringify({ type, data, options })} id={`${id}-cfg`} />
<script>
  import Chart from 'chart.js/auto';
  document.querySelectorAll('canvas[id]').forEach((canvas) => {
    const cfgEl = document.getElementById(`${canvas.id}-cfg`);
    if (!cfgEl) return;
    new Chart(canvas as HTMLCanvasElement, JSON.parse(cfgEl.textContent!));
  });
</script>
